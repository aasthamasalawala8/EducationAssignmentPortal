@inherits LayoutComponentBase
@using EducationAssignmentPortal.Services
@inject NavigationManager Navigation
@inject UserService UserService

<div class="d-flex">

    <!-- Sidebar -->
    <div class="student-sidebar d-flex flex-column bg-dark text-white p-3" style="width: 250px;">
        <h4 class="student-title mb-4">Student Panel</h4>
        <NotificationBell />

        <nav class="student-nav flex-grow-1">
            <!-- Dashboard Link (this will load Student Dashboard content) -->
            <NavLink href="/student-dashboard" 
                     class="student-link text-white d-flex align-items-center py-2 px-3 mb-2 rounded"
                     Match="NavLinkMatch.All">
                <i class="bi bi-house-door me-2"></i> Dashboard
            </NavLink>

            <!-- Assignments -->
            <NavLink href="/student/assignments"
                     class="student-link text-white d-flex align-items-center py-2 px-3 mb-2 rounded">
                <i class="bi bi-journal-text me-2"></i> Assignments
            </NavLink>

            <!-- My Courses -->
            <NavLink href="/student/mycourses"
                     class="student-link text-white d-flex align-items-center py-2 px-3 mb-2 rounded">
                <i class="bi bi-book me-2"></i> My Courses
            </NavLink>

            <!-- Results -->
            <NavLink href="/student/grades"
                     class="student-link text-white d-flex align-items-center py-2 px-3 mb-2 rounded">
                <i class="bi bi-bar-chart me-2"></i> Grades
            </NavLink>
        </nav>

        <!-- Logout Button -->
        <button class="btn btn-danger w-100 py-2 mt-3" @onclick="Logout">
            <i class="bi bi-box-arrow-right me-2"></i> Logout
        </button>
    </div>

    <!-- Main Content -->
    <div class="flex-fill p-4 student-content">
        @Body
    </div>

</div>

@code {
    void Logout()
    {
     UserService.Logout();
        Navigation.NavigateTo("/login?logout=true"); // Redirect to login page after logout
    }
}
